---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import CtaBlock from '../../components/CtaBlock.astro';
import Icon from '../../components/Icon.astro';
import { locations, getLocationBySlug } from '../../data/locations.js';
import { site } from '../../data/site.js';

export function getStaticPaths() {
  return locations.map(loc => ({ params: { slug: loc.slug }, props: { loc } }));
}

const { loc } = Astro.props;
const nearbyLocs = (loc.nearby || []).map(s => getLocationBySlug(s)).filter(Boolean);

const title = `Property Management in ${loc.name} | Guaranteed Rent for Landlords`;
const description = `Professional property management and guaranteed rent for ${loc.name} landlords. Long-term agreements, full compliance, fixed monthly income. Part of the TIFA Life Group.`;

// LocalBusiness schema scoped to this town
const localSchema = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: `${site.name} - ${loc.name}`,
  url: `${site.baseUrl}/property-management/${loc.slug}/`,
  telephone: site.phoneE164,
  email: site.email,
  description,
  areaServed: { '@type': 'City', name: loc.name },
  parentOrganization: { '@type': 'Organization', name: site.name, url: site.baseUrl },
  address: { '@type': 'PostalAddress', addressLocality: site.hqCity, addressRegion: site.hqRegion, addressCountry: 'GB' },
};
---
<BaseLayout title={title} description={description} schema={localSchema} pathname={`/property-management/${loc.slug}/`}>
  <Hero
    eyebrow={`Property management · ${loc.county}`}
    title={loc.headline}
    subtitle={loc.intro}
    primaryCta={{ label: `Discuss Your ${loc.name} Property`, href: '/contact/' }}
    secondaryCta={{ label: 'How Our Partnership Works', href: '/solutions/' }}
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Areas', href: '/areas/' }, { label: loc.name }]}
  />

  <section class="py-20">
    <div class="container-tight grid lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2 space-y-6 text-gray-700 leading-relaxed">
        <h2 class="text-2xl md:text-3xl font-serif text-ink">Why {loc.name} landlords work with TIFA Property</h2>
        <p>{loc.rentalContext}</p>
        <p>Our partnership model is built around removing operational risk from the landlord. That means full compliance handling, full tenant management, and fixed monthly income on a long-term agreement. The day-to-day stops being your problem. The asset stays yours.</p>
        <ul class="grid sm:grid-cols-2 gap-3 mt-4">
          {[
            'Fixed monthly rent under long-term agreement',
            'No void or arrears risk for the landlord',
            `Local team operating across ${loc.county}`,
            'Rent Smart Wales, EPC, gas, electrical compliance handled',
            'One point of contact, every issue',
            'Properties protected as long-term assets',
          ].map(item => (
            <li class="flex items-start gap-3 bg-cream rounded p-3 text-sm">
              <span class="w-5 h-5 rounded bg-teal text-white flex items-center justify-center shrink-0 mt-0.5"><Icon name="check" class="w-3.5 h-3.5"/></span>{item}
            </li>
          ))}
        </ul>

        <h2 class="text-2xl md:text-3xl font-serif text-ink mt-8">Areas of {loc.name} we work in</h2>
        <p>Our team covers the full {loc.name} area, including:</p>
        <div class="flex flex-wrap gap-2">
          {loc.neighbourhoods.map(n => (
            <span class="inline-block bg-white border border-gray-200 rounded-full px-3 py-1 text-sm text-gray-700">{n}</span>
          ))}
        </div>

        <h2 class="text-2xl md:text-3xl font-serif text-ink mt-8">Two ways we work</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="bg-white border border-gray-200 rounded-lg p-6">
            <h3 class="font-serif text-lg">Guaranteed Rent</h3>
            <p class="mt-2 text-sm text-gray-600">Fixed monthly rent regardless of occupancy. Long-term agreement. We absorb the operational risk.</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-lg p-6">
            <h3 class="font-serif text-lg">Fully Managed</h3>
            <p class="mt-2 text-sm text-gray-600">Full management of your {loc.name} portfolio with strategic oversight, compliance, and reporting.</p>
          </div>
        </div>
      </div>

      <aside class="space-y-6 self-start">
        <div class="bg-navy text-white rounded-lg p-6">
          <div class="text-xs uppercase tracking-widest text-teal-light">Get a quote for {loc.name}</div>
          <p class="mt-3 text-sm text-white/80">Tell us about your {loc.name} property. We'll come back within 24 hours with a recommendation.</p>
          <a href="/contact/" class="btn-primary mt-5 w-full justify-center">Request a Call Back
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <div class="mt-4 text-xs text-white/60 space-y-1">
            <div>{site.email}</div>
            <div>{site.phone}</div>
          </div>
        </div>
        {nearbyLocs.length > 0 && (
          <div class="bg-cream rounded-lg p-6">
            <div class="text-xs uppercase tracking-widest text-gray-500">Also covering</div>
            <ul class="mt-3 space-y-1.5 text-sm">
              {nearbyLocs.map(n => (
                <li><a class="text-teal hover:underline" href={`/property-management/${n.slug}/`}>Property management in {n.name}</a></li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </section>

  <CtaBlock
    title={`Talk to us about your ${loc.name} property.`}
    subtitle={`A no-obligation conversation about how the partnership model would work for your ${loc.name} property or portfolio.`}
    primaryLabel="Start a Conversation"
  />
</BaseLayout>
