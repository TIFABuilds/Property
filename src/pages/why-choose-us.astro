---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBlock from '../components/CtaBlock.astro';
import Icon from '../components/Icon.astro';

const reasons = [
  { icon: 'trend',  title: 'Predictable income',                    body: 'Fixed monthly rent under long-term agreements. No occupancy risk falls on you.' },
  { icon: 'eye',    title: 'Professional property oversight',       body: 'Inspections, compliance, and condition management handled to a consistent standard.' },
  { icon: 'users',  title: 'No tenant stress',                      body: 'You never deal with an occupant. We are your single point of contact for everything.' },
  { icon: 'no',     title: 'Reduced exposure to voids and arrears', body: 'We absorb the operational risk of letting. You receive monthly income regardless.' },
  { icon: 'doc',    title: 'Long-term agreements',                  body: 'Multi-year stability beats short-term yield. Our model is built for that priority.' },
  { icon: 'heart',  title: 'Properties used ethically',              body: 'Where used for supported accommodation, properties are operated to a professional standard with genuine social value.' },
];

const traditional = ['Void periods eat into income','Arrears risk with every tenant','Constant tenant turnover','Day-to-day management required','Reactive approach to issues'];
const tifa = ['Guaranteed monthly income','No exposure to arrears','Long-term, stable agreements','Complete hands-off management','Proactive property oversight'];
---
<BaseLayout
  title="Why Choose TIFA Property"
  description="Predictable monthly income, professional property oversight, and zero exposure to voids or arrears. Why South Wales landlords choose TIFA Property over traditional letting agents."
>
  <Hero
    eyebrow="Why TIFA Property"
    title="Because risk shouldn't be part of the deal."
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Why Choose Us' }]}
  />

  <section class="py-20">
    <div class="container-tight grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reasons.map(r => (
        <div class="card">
          <div class="w-10 h-10 rounded bg-navy text-white flex items-center justify-center"><Icon name={r.icon} class="w-5 h-5"/></div>
          <h3 class="mt-4 text-xl font-serif">{r.title}</h3>
          <p class="mt-2 text-gray-600 leading-relaxed">{r.body}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="py-20 bg-navy text-white">
    <div class="container-tight max-w-3xl text-center">
      <blockquote class="text-2xl md:text-3xl font-serif leading-snug">
        "We don't chase maximum rent. We prioritise stability and asset protection."
      </blockquote>
      <div class="mt-4 text-xs uppercase tracking-widest text-teal-light">TIFA Property philosophy</div>
    </div>
  </section>

  <section class="py-20">
    <div class="container-tight max-w-5xl">
      <h2 class="text-3xl md:text-4xl font-serif">Traditional letting vs TIFA Property.</h2>
      <div class="mt-10 grid md:grid-cols-2 gap-6">
        <div class="bg-cream border border-gray-200 rounded-lg p-7">
          <h3 class="font-serif text-lg">Traditional letting</h3>
          <ul class="mt-4 space-y-2.5">
            {traditional.map(t => (
              <li class="flex items-start gap-3 text-sm text-gray-700">
                <span class="w-5 h-5 rounded bg-red-50 text-red-600 flex items-center justify-center shrink-0"><Icon name="cross" class="w-3.5 h-3.5"/></span>{t}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-navy text-white rounded-lg p-7">
          <h3 class="font-serif text-lg text-teal-light">TIFA Property partnership</h3>
          <ul class="mt-4 space-y-2.5">
            {tifa.map(t => (
              <li class="flex items-start gap-3 text-sm text-white/90">
                <span class="w-5 h-5 rounded bg-teal text-white flex items-center justify-center shrink-0"><Icon name="check" class="w-3.5 h-3.5"/></span>{t}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CtaBlock
    title="Ready to explore a partnership?"
    subtitle="Join landlords across South Wales who've found a more stable way to manage their properties."
    primaryLabel="Start a Conversation"
  />
</BaseLayout>
