---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CtaBlock from '../components/CtaBlock.astro';
import { locations } from '../data/locations.js';

const grouped = locations.reduce((acc, loc) => {
  acc[loc.region] ||= [];
  acc[loc.region].push(loc);
  return acc;
}, {});
---
<BaseLayout
  title="Areas We Cover Across Wales"
  description="Property management coverage across South Wales and beyond. Browse every town and city we operate in, from Swansea and Cardiff to the South Wales valleys."
>
  <Hero
    eyebrow="Coverage"
    title="Property management across Wales."
    subtitle="Our partnership model is available across South Wales and into the wider region. Each area has its own page covering local rental context, neighbourhoods, and how we operate there."
    breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Areas We Cover' }]}
  />

  <section class="py-20">
    <div class="container-tight space-y-14">
      {Object.entries(grouped).map(([region, locs]) => (
        <div>
          <h2 class="text-2xl font-serif">{region}</h2>
          <div class="mt-6 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
            {locs.map(loc => (
              <a href={`/property-management/${loc.slug}/`} class="border border-gray-200 rounded p-4 hover:border-teal hover:bg-cream transition-colors">
                <div class="font-medium">{loc.name}</div>
                <div class="text-xs text-gray-500 mt-0.5">{loc.county}</div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <CtaBlock />
</BaseLayout>
