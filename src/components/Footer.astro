---
import { site } from '../data/site.js';
import { locations } from '../data/locations.js';
const year = new Date().getFullYear();
const topAreas = locations.slice(0, 8);
---
<footer class="bg-navy-deep text-white/80 mt-24">
  <div class="container-tight py-16 grid gap-10 lg:grid-cols-4">
    <div class="lg:col-span-2">
      <div class="font-serif text-2xl text-white">TIFA Property</div>
      <p class="mt-4 max-w-md text-sm leading-relaxed">
        Professional property management and guaranteed rent solutions for landlords across South Wales. Based in Swansea. Part of the {site.parentGroup}.
      </p>
      <a href="/contact/" class="inline-flex items-center gap-2 mt-6 text-teal-light hover:text-white text-sm">
        Partner With TIFA Property
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest text-white/50">Navigation</div>
      <ul class="mt-4 space-y-2 text-sm">
        {site.nav.map(item => (
          <li><a href={item.href} class="hover:text-white">{item.label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <div class="text-xs uppercase tracking-widest text-white/50">Contact</div>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a></li>
        <li><a href={`tel:${site.phoneE164}`} class="hover:text-white">{site.phone}</a></li>
        <li><a href={`https://wa.me/${site.whatsapp.replace('+','')}`} class="hover:text-white">WhatsApp</a></li>
      </ul>
      <div class="text-xs uppercase tracking-widest text-white/50 mt-8">Top Coverage Areas</div>
      <ul class="mt-3 grid grid-cols-2 gap-x-4 gap-y-1 text-sm">
        {topAreas.map(loc => (
          <li><a href={`/property-management/${loc.slug}/`} class="hover:text-white">{loc.name}</a></li>
        ))}
      </ul>
      <a href="/areas/" class="inline-block mt-3 text-teal-light text-sm hover:text-white">All areas →</a>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="container-tight py-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs text-white/50">
      <div>© {year} TIFA Property. Part of the {site.parentGroup}.</div>
      <div>Property management with stability built in.</div>
    </div>
  </div>
</footer>
