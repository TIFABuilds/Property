---
const {
  title = "Let's Discuss Your Property",
  subtitle = "We offer a no-obligation conversation to explore whether a long-term partnership is right for you. Based in Swansea. We work with landlords across South Wales.",
  primaryLabel = "Talk to Us About Your Property",
  primaryHref = "/contact/",
  secondaryLabel = null,
  secondaryHref = null,
} = Astro.props;
---
<section class="bg-navy text-white">
  <div class="container-tight py-20 text-center">
    <h2 class="text-3xl md:text-4xl font-serif">{title}</h2>
    <p class="mt-4 text-white/80 max-w-2xl mx-auto">{subtitle}</p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a href={primaryHref} class="btn-primary">
        {primaryLabel}
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      {secondaryLabel && <a href={secondaryHref} class="btn-ghost">{secondaryLabel}</a>}
    </div>
    <div class="mt-6 text-xs text-white/50">Part of the TIFA Life Group</div>
  </div>
</section>
