---
import { site } from '../data/site.js';
const current = Astro.url.pathname;
const isCurrent = (href) => href === '/' ? current === '/' : current.startsWith(href);
---
<header class="bg-navy text-white sticky top-0 z-40 border-b border-white/5">
  <div class="container-tight flex items-center justify-between py-4">
    <a href="/" class="font-serif text-2xl tracking-wide">TIFA <span class="text-teal-light">Property</span></a>
    <nav class="hidden lg:flex items-center gap-7" aria-label="Primary">
      {site.nav.map(item => (
        <a
          href={item.href}
          class={`text-sm hover:text-teal-light transition-colors ${isCurrent(item.href) ? 'text-teal-light' : 'text-white/85'}`}
          aria-current={isCurrent(item.href) ? 'page' : undefined}
        >{item.label}</a>
      ))}
    </nav>
    <a href="/contact/" class="btn-primary text-sm py-2 px-4">Get in Touch
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
    </a>
  </div>
  <details class="lg:hidden border-t border-white/5">
    <summary class="container-tight py-3 cursor-pointer text-sm select-none flex items-center justify-between">
      <span>Menu</span>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
    </summary>
    <nav class="container-tight pb-4 flex flex-col gap-2" aria-label="Mobile">
      {site.nav.map(item => (
        <a href={item.href} class="text-sm py-1 text-white/85 hover:text-teal-light">{item.label}</a>
      ))}
    </nav>
  </details>
</header>
