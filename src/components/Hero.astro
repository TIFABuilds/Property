---
const { eyebrow, title, subtitle, primaryCta, secondaryCta, breadcrumb = null } = Astro.props;
---
<section class="relative overflow-hidden bg-navy text-white">
  <div class="absolute inset-0 bg-gradient-to-br from-navy via-navy-light to-navy-deep opacity-95"></div>
  <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 30%, #3a8a7e 0%, transparent 50%), radial-gradient(circle at 80% 70%, #243a52 0%, transparent 50%);"></div>
  <div class="container-tight relative py-20 lg:py-28">
    {breadcrumb && (
      <nav class="text-xs text-white/60 mb-6" aria-label="Breadcrumb">
        <ol class="flex gap-2">
          {breadcrumb.map((b, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && <span>›</span>}
              {b.href ? <a href={b.href} class="hover:text-white">{b.label}</a> : <span>{b.label}</span>}
            </li>
          ))}
        </ol>
      </nav>
    )}
    {eyebrow && <div class="text-teal-light text-sm font-semibold tracking-widest uppercase mb-4">{eyebrow}</div>}
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif leading-tight max-w-4xl">{title}</h1>
    {subtitle && <p class="mt-6 text-lg text-white/80 max-w-2xl leading-relaxed">{subtitle}</p>}
    {(primaryCta || secondaryCta) && (
      <div class="mt-10 flex flex-wrap gap-3">
        {primaryCta && (
          <a href={primaryCta.href} class="btn-primary">
            {primaryCta.label}
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        )}
        {secondaryCta && (
          <a href={secondaryCta.href} class="btn-ghost">{secondaryCta.label}</a>
        )}
      </div>
    )}
  </div>
</section>
